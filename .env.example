# ── YouTube Automation .env ──────────────────────────
# Copy this to .env and fill in your keys

# Claude API (free tier: claude.ai → API Keys)
# Free tier gives ~$5 credit. Haiku model is cheapest.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Pexels API (free at https://www.pexels.com/api/)
# Free: 200 requests/hour, 20,000/month — plenty for daily videos
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube OAuth client secrets file path
# Get from Google Cloud Console (see SETUP.md for steps)
YOUTUBE_CLIENT_SECRETS=client_secrets.json
